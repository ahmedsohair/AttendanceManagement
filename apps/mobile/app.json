{
  "expo": {
    "name": "ExamPulse",
    "slug": "attendance-management-system",
    "owner": "ahmedsohair",
    "scheme": "attendancemanagement",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Allow ExamPulse to access the camera for live student ID scanning.",
          "enableFrameProcessors": true
        }
      ]
    ],
    "android": {
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.ahmedsohair.attendancemanagement"
    },
    "ios": {
      "bundleIdentifier": "com.ahmedsohair.attendancemanagement"
    }
  }
}
